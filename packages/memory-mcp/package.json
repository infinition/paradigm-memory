{
  "name": "@paradigm-memory/memory-mcp",
  "version": "0.1.0",
  "description": "Local-first, audited memory MCP server for coding agents (Claude Code, Cursor, Cline, OpenCode, Continue). Cognitive-map retrieval, propose/review flow, dream consolidation.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabien POLLY",
  "homepage": "https://github.com/infinition/paradigm-memory",
  "repository": {
    "type": "git",
    "url": "https://github.com/infinition/paradigm-memory",
    "directory": "packages/memory-mcp"
  },
  "bugs": {
    "url": "https://github.com/infinition/paradigm-memory/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "agent",
    "claude-code",
    "cursor",
    "cline",
    "opencode",
    "continue",
    "rag",
    "cognitive-map",
    "local-first"
  ],
  "bin": {
    "paradigm-memory-mcp": "./src/server.mjs",
    "paradigm-memory-http": "./src/http-server.mjs"
  },
  "main": "./src/memory-service.mjs",
  "exports": {
    ".": "./src/memory-service.mjs",
