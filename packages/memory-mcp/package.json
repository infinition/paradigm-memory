    "./http-server": "./src/http-server.mjs"
  },
  "files": [
    "src/**/*.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/server.mjs"
  },
  "dependencies": {
