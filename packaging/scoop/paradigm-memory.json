  "license": "Apache-2.0",
  "depends": "nodejs22",
  "url": "https://registry.npmjs.org/@paradigm-memory/memory-cli/-/memory-cli-0.1.0.tgz",
  "hash": "REPLACE_WITH_NPM_TARBALL_SHA256",
  "extract_dir": "package",
  "bin": [["src/cli.mjs", "paradigm"]],
  "post_install": [
    "Write-Host 'Run: paradigm version'",
