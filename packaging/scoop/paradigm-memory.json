  "license": "Apache-2.0",
  "depends": "nodejs22",
  "url": "https://github.com/infinition/paradigm-memory/releases/download/v0.1.2/paradigm-memory-cli-v0.1.2-windows-x64.tar.gz",
  "hash": "REPLACE_WITH_GITHUB_RELEASE_SHA256",
  "bin": [
    [
      "bin/paradigm.cmd",
      "paradigm"
    ],
    [
      "bin/paradigm-memory-mcp.cmd",
      "paradigm-memory-mcp"
    ],
    [
      "bin/paradigm-memory-http.cmd",
      "paradigm-memory-http"
